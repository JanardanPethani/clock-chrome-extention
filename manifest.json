{
  "manifest_version": 3,
  "name": "Time Utils",
  "version": "1.0",
  "description": "Shows an analog and digital clock with today's date, and includes a session timer.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/clock_icon.png",
      "48": "assets/clock_icon.png",
      "128": "assets/clock_icon.png"
    }
  },
  "permissions": ["storage", "notifications", "background"],
  "background": {
    "service_worker": "background.js"
  }
}
